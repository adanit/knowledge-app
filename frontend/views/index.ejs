<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Knowledge Base</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <header>
        <h1>&#128218; Knowledge Base</h1>
        <a href="/new" class="btn btn-primary">+ Novo Comando</a>
    </header>

    <div class="container">
        <aside class="sidebar">
            <h3>Categorias</h3>
            <a href="/" class="<%= selectedCategory === '' ? 'active' : '' %>">Todas</a>
            <% categories.forEach(function(cat) { %>
                <a href="/?category=<%= encodeURIComponent(cat) %>"
                   class="<%= selectedCategory === cat ? 'active' : '' %>">
                    <%= cat %>
                </a>
            <% }); %>
        </aside>

        <main class="main">
            <% if (error) { %>
                <div class="alert-error"><%= error %></div>
            <% } %>

            <div class="search-bar">
                <input type="text" id="searchInput" placeholder="Buscar por titulo ou categoria..." oninput="filterCommands()">
            </div>

            <% if (commands.length === 0) { %>
                <div class="empty-state">
                    <p>Nenhum comando encontrado.</p>
                    <a href="/new" class="btn btn-primary" style="margin-top: 1rem; display: inline-block;">
                        Adicionar primeiro comando
                    </a>
                </div>
            <% } else { %>
                <div class="commands-grid" id="commandsGrid">
                    <% commands.forEach(function(cmd) { %>
                        <div class="card"
                             data-title="<%= cmd.title.toLowerCase() %>"
                             data-desc="<%= (cmd.description || '').toLowerCase() %>">
                            <span class="category-badge"><%= cmd.category %></span>
                            <h3><%= cmd.title %></h3>
                            <% if (cmd.description) { %>
                                <p class="description"><%= cmd.description %></p>
                            <% } %>
                            <div class="command-preview"><%= cmd.command %></div>
                            <div style="margin-top: 0.8rem;">
                                <a href="/command/<%= cmd.id %>">Ver detalhes &rarr;</a>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        </main>
    </div>

    <script>
        function filterCommands() {
            var query = document.getElementById('searchInput').value.toLowerCase();
            var cards = document.querySelectorAll('.card');
            cards.forEach(function(card) {
                var match = card.dataset.title.includes(query) || card.dataset.desc.includes(query);
                card.style.display = match ? '' : 'none';
            });
        }
    </script>
</body>
</html>
